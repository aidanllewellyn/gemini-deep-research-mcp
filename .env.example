# Copy to .env and fill in values locally. Do not commit .env.
GEMINI_API_KEY=

# Optional model/tier controls.
GEMINI_DEFAULT_TIER=standard
# GEMINI_AGENT_ID=

# Local development:
MCP_TRANSPORT=stdio

# Hosted HTTP mode:
# MCP_TRANSPORT=http
# MCP_HOST=127.0.0.1
# MCP_PORT=8000
# MCP_AUTH_TOKEN=
# MCP_DB_PATH=./data/jobs.db
